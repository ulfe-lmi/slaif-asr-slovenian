{
  "schema_version": "1.0",
  "adapter_id": "sl-si-joint-adapter-v1",
  "target_module": "model.joint",
  "adapter_type": "nemo.collections.common.parts.adapter_modules.LinearAdapter",
  "strategy_type": "nemo.core.classes.mixins.adapter_mixin_strategies.ResidualAddAdapterStrategy",
  "input_dimension": "derive_from_model.joint.joint_hidden",
  "bottleneck_dimension": 32,
  "activation": "swish",
  "normalization_position": "pre",
  "dropout": 0.0,
  "stochastic_depth": 0.0,
  "l2_auxiliary_penalty": 0.0,
  "zero_initialized_final_projection": true,
  "enabled_by_default": false,
  "target_language": "sl-SI",
  "trainable_parameter_formula": "2 * joint_hidden * bottleneck_dimension + 2 * joint_hidden",
  "allowed_trainable_scope": "named_adapter_only"
}
